---
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  items: Crumb[];
}
const { items } = Astro.props;
---

<nav class="flex items-center gap-1.5 text-xs text-muted-foreground/60 mb-6" aria-label="面包屑">
  <a href="/" class="hover:text-primary transition-colors">
    <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
      <polyline points="9,22 9,12 15,12 15,22"/>
    </svg>
  </a>
  {items.map((item, i) => (
    <span class="flex items-center gap-1.5">
      <svg class="w-3 h-3 text-muted-foreground/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="m9 18 6-6-6-6"/>
      </svg>
      {item.href ? (
        <a href={item.href} class="hover:text-primary transition-colors">{item.label}</a>
      ) : (
        <span class="text-foreground/70">{item.label}</span>
      )}
    </span>
  ))}
</nav>
