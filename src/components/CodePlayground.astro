---
interface Props {
  code: string;
  language?: string;
}
const { code, language = "javascript" } = Astro.props;
---

<div class="playground my-6 rounded-xl border border-border/40 overflow-hidden" data-animate>
  <div class="flex items-center justify-between px-4 py-2.5 bg-[#0d1117] border-b border-border/30">
    <div class="flex items-center gap-2">
      <div class="flex gap-1.5">
        <span class="w-2.5 h-2.5 rounded-full bg-red-400/80"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-yellow-400/80"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-green-400/80"></span>
      </div>
      <span class="text-[10px] text-muted-foreground/50 font-mono uppercase">{language}</span>
    </div>
    <button
      class="playground-run flex items-center gap-1.5 px-3 py-1 rounded-md text-xs bg-green-600/80 text-white hover:bg-green-500 transition-all duration-200 active:scale-95"
      data-code={code.trim()}
    >
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg>
      运行
    </button>
  </div>
  <div class="bg-[#0d1117] p-3">
    <pre class="text-sm font-mono text-[#e6edf3] overflow-x-auto"><code>{code.trim()}</code></pre>
  </div>
  <div class="playground-output hidden border-t border-border/30 bg-white/3 p-3">
    <p class="text-[10px] text-muted-foreground/50 uppercase tracking-wider mb-2">输出</p>
    <pre class="text-sm font-mono text-green-400/90 whitespace-pre-wrap break-all"></pre>
  </div>
</div>

<script>
  document.querySelectorAll(".playground-run").forEach((btn) => {
    btn.addEventListener("click", () => {
      const code = (btn as HTMLElement).dataset.code || "";
      const output = btn.closest(".playground")?.querySelector(".playground-output pre");
      if (!output) return;

      const outputContainer = btn.closest(".playground")?.querySelector(".playground-output") as HTMLElement;
      outputContainer?.classList.remove("hidden");

      try {
        const logs: string[] = [];
        const fakeConsole = {
          log: (...args: any[]) => logs.push(args.map(String).join(" ")),
          error: (...args: any[]) => logs.push("[Error] " + args.map(String).join(" ")),
          warn: (...args: any[]) => logs.push("[Warn] " + args.map(String).join(" ")),
        };
        const fn = new Function("console", code);
        const result = fn(fakeConsole);
        if (result !== undefined) logs.push(String(result));
        output.textContent = logs.join("\n") || "(无输出)";
      } catch (e: any) {
        output.textContent = "[Error] " + e.message;
        output.className = "text-sm font-mono text-red-400/90 whitespace-pre-wrap break-all";
      }
    });
  });
</script>
