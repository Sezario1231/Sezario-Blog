---
---
<div id="music-player" class="fixed bottom-20 left-6 z-50 hidden">
  <div class="music-mini glass-card rounded-2xl p-3 w-48 border border-border/40 shadow-xl cursor-pointer" id="music-toggle">
    <div class="flex items-center gap-2.5">
      <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-primary/20 to-orange-300/20 dark:from-primary/30 dark:to-emerald-400/20 flex items-center justify-center shrink-0 music-disc">
        <svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>
        </svg>
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-xs font-medium truncate" id="music-title">未播放</p>
        <p class="text-[10px] text-muted-foreground/50 truncate" id="music-artist">点击播放</p>
      </div>
      <button class="shrink-0 w-7 h-7 flex items-center justify-center rounded-full hover:bg-white/5 transition-colors" id="music-play-btn">
        <svg class="w-3.5 h-3.5 text-foreground" viewBox="0 0 24 24" fill="currentColor" id="play-icon">
          <polygon points="5,3 19,12 5,21"/>
        </svg>
      </button>
    </div>
    <div class="mt-2 h-1 rounded-full bg-muted/30 overflow-hidden">
      <div class="h-full bg-primary/60 rounded-full transition-all duration-300" id="music-progress" style="width: 0%"></div>
    </div>
  </div>

  <div class="music-expanded glass-card rounded-2xl p-4 w-64 border border-border/40 shadow-xl hidden mt-2" id="music-panel">
    <p class="text-xs font-semibold mb-2">播放列表</p>
    <div class="space-y-1.5" id="music-playlist"></div>
    <div class="flex items-center gap-2 mt-3 pt-3 border-t border-border/30">
      <input type="range" min="0" max="100" value="70" class="flex-1 h-1 accent-primary" id="music-volume" />
      <svg class="w-3.5 h-3.5 text-muted-foreground/50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polygon points="11,5 6,9 2,9 2,15 6,15 11,19"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>
      </svg>
    </div>
  </div>
</div>

<script>
  const playlist = [
    { title: "Oh My Saturday", artist: "aroundyou", url: "/music/aroundyou-oh-my-saturday-240376.mp3" },
    { title: "Calm Classical Piano", artist: "clavier-music", url: "/music/clavier-music-calm-classical-piano-291012.mp3" },
    { title: "Native American Flute", artist: "hdhazard", url: "/music/hdhazard-native-american-flute-277509.mp3" },
    { title: "Soft Background Music", artist: "lnplusmusic", url: "/music/lnplusmusic-soft-background-music-424109.mp3" },
    { title: "Snowfall Ambient Music", artist: "smccleery", url: "/music/smccleery-snowfall-ambient-music-258684.mp3" },
  ];

  // ---- 全局状态（跨页面持久） ----
  let currentTrack = 0;
  let playing = false;
  let audio: HTMLAudioElement | null = null;
  let progressRaf = 0;

  // ---- 创建/复用 audio ----
  function getAudio(): HTMLAudioElement {
    if (audio) return audio;
    audio = new Audio();
    audio.preload = "auto";
    audio.volume = 0.7;
    audio.addEventListener("ended", () => {
      currentTrack = (currentTrack + 1) % playlist.length;
      loadTrack(currentTrack, true);
    });
    return audio;
  }

  // ---- 加载并可选播放 ----
  function loadTrack(index: number, autoplay: boolean) {
    currentTrack = index;
    const a = getAudio();
    const src = playlist[index].url;
    if (a.src !== location.origin + src && a.src !== src) {
      a.src = src;
      a.load();
    }
    if (autoplay) {
      a.play().then(() => { playing = true; syncUI(); }).catch(() => { playing = false; syncUI(); });
    } else {
      playing = false;
      syncUI();
    }
  }

  // ---- 同步 UI ----
  function syncUI() {
    const icon = document.getElementById("play-icon");
    if (icon) {
      icon.innerHTML = playing
        ? '<rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/>'
        : '<polygon points="5,3 19,12 5,21"/>';
    }
    const player = document.getElementById("music-player");
    const disc = player?.querySelector(".music-disc") as HTMLElement;
    if (disc) disc.style.animationPlayState = playing ? "running" : "paused";

    const titleEl = document.getElementById("music-title");
    const artistEl = document.getElementById("music-artist");
    const t = playlist[currentTrack];
    if (titleEl) titleEl.textContent = playing || (audio && !audio.paused) ? t.title : "未播放";
    if (artistEl) artistEl.textContent = playing || (audio && !audio.paused) ? t.artist : "点击播放";
  }

  // ---- 进度条轮询 ----
  function startProgressLoop() {
    if (progressRaf) return;
    function tick() {
      const bar = document.getElementById("music-progress");
      if (audio && bar && audio.duration) {
        bar.style.width = `${(audio.currentTime / audio.duration) * 100}%`;
      }
      progressRaf = requestAnimationFrame(tick);
    }
    progressRaf = requestAnimationFrame(tick);
  }

  // ---- 初始化（每次页面加载） ----
  function initMusicPlayer() {
    const player = document.getElementById("music-player");
    if (!player) return;
    player.classList.remove("hidden");

    const toggle = document.getElementById("music-toggle");
    const panel = document.getElementById("music-panel");
    const playBtn = document.getElementById("music-play-btn");
    const playlistEl = document.getElementById("music-playlist");
    const volumeEl = document.getElementById("music-volume") as HTMLInputElement;

    // 确保 audio 存在
    getAudio();

    // 音量同步
    if (volumeEl) {
      volumeEl.value = String(audio!.volume * 100);
      volumeEl.oninput = () => { if (audio) audio.volume = volumeEl.valueAsNumber / 100; };
    }

    // 渲染播放列表
    if (playlistEl) {
      playlistEl.innerHTML = playlist.map((t, i) => `
        <div class="flex items-center gap-2 px-2 py-1.5 rounded-lg hover:bg-muted/30 cursor-pointer transition-colors music-track" data-index="${i}">
          <span class="text-[10px] text-muted-foreground/40 w-3">${i + 1}</span>
          <div class="flex-1 min-w-0">
            <p class="text-xs truncate">${t.title}</p>
            <p class="text-[10px] text-muted-foreground/50 truncate">${t.artist}</p>
          </div>
        </div>
      `).join("");
    }

    // 事件绑定（每次重建 DOM 都重新绑定）
    toggle?.addEventListener("click", () => panel?.classList.toggle("hidden"));

    playBtn?.addEventListener("click", (e) => {
      e.stopPropagation();
      const a = getAudio();
      if (!a.src) {
        loadTrack(currentTrack, true);
        return;
      }
      if (playing) {
        a.pause();
        playing = false;
      } else {
        a.play().then(() => { playing = true; syncUI(); }).catch(() => {});
        playing = true;
      }
      syncUI();
    });

    playlistEl?.addEventListener("click", (e) => {
      const track = (e.target as HTMLElement).closest(".music-track") as HTMLElement;
      if (track) {
        const idx = parseInt(track.dataset.index || "0");
        loadTrack(idx, true);
      }
    });

    syncUI();
    startProgressLoop();
  }

  document.addEventListener("DOMContentLoaded", initMusicPlayer);
  document.addEventListener("astro:page-load", initMusicPlayer);
</script>

<style>
  .music-disc {
    animation: spin 3s linear infinite;
    animation-play-state: paused;
  }
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
</style>
