---
---
<div id="cosmic-ending" class="cosmic-ending">
  <div class="cosmic-stars"></div>
  <div class="cosmic-text">
    <p class="text-2xl md:text-3xl font-bold text-white/90 mb-3">你已到达宇宙的尽头</p>
    <p class="text-sm text-white/50">感谢你一路看到这里</p>
  </div>
</div>

<style>
  .cosmic-ending {
    position: fixed;
    inset: 0;
    z-index: 200;
    pointer-events: none;
    opacity: 0;
    background: radial-gradient(ellipse at center, #0a0a1a 0%, #000 100%);
    transition: opacity 0.8s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cosmic-ending.active {
    opacity: 1;
    pointer-events: auto;
  }
  .cosmic-stars {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 20% 30%, white 50%, transparent),
      radial-gradient(1px 1px at 40% 70%, white 50%, transparent),
      radial-gradient(1.5px 1.5px at 60% 20%, white 50%, transparent),
      radial-gradient(1px 1px at 80% 50%, white 50%, transparent),
      radial-gradient(1px 1px at 10% 80%, white 50%, transparent),
      radial-gradient(1.5px 1.5px at 70% 90%, white 50%, transparent),
      radial-gradient(1px 1px at 50% 10%, white 50%, transparent),
      radial-gradient(1px 1px at 90% 40%, white 50%, transparent),
      radial-gradient(1px 1px at 30% 60%, white 50%, transparent),
      radial-gradient(1px 1px at 85% 15%, white 50%, transparent);
    animation: cosmic-twinkle 4s ease-in-out infinite alternate;
  }
  @keyframes cosmic-twinkle {
    0% { opacity: 0.4; }
    100% { opacity: 1; }
  }
  .cosmic-text {
    position: relative;
    z-index: 1;
    text-align: center;
    opacity: 0;
    transform: translateY(20px);
    transition: all 1s ease 0.3s;
  }
  .cosmic-ending.active .cosmic-text {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  function initCosmicEnding() {
    return;
    let active = false;

    function check() {
      const scrollBottom = window.scrollY + window.innerHeight;
      const docHeight = document.documentElement.scrollHeight;
      if (scrollBottom >= docHeight - 30 && !active && docHeight > 600) {
        active = true;
        el.classList.add("active");
      } else if (scrollBottom < docHeight - 200 && active) {
        active = false;
        el.classList.remove("active");
      }
    }

    window.addEventListener("scroll", check, { passive: true });

    el.addEventListener("click", () => {
      active = false;
      el.classList.remove("active");
    });
  }

  document.addEventListener("DOMContentLoaded", initCosmicEnding);
  document.addEventListener("astro:page-load", initCosmicEnding);
</script>
