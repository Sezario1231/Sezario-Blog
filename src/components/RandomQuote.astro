---
import { getSupabase } from "@/lib/supabase";

const supabase = getSupabase();
const { data: quotesData } = await supabase.from("quotes").select("*");

interface Quote { text: string; author: string; }
const quotes: Quote[] = (quotesData || []) as Quote[];
const defaultQuotes: Quote[] = [
  { text: "代码是写给人看的，附带能在机器上运行。", author: "Harold Abelson" },
  { text: "先让它工作，再让它正确，再让它快。", author: "Kent Beck" },
  { text: "任何足够先进的技术都与魔法无异。", author: "Arthur C. Clarke" },
];
const allQuotes = quotes.length > 0 ? quotes : defaultQuotes;
const randomQuote = allQuotes[Math.floor(Math.random() * allQuotes.length)];
---

<div class="quote-card relative p-6 rounded-2xl border border-border/40 bg-card/50 overflow-hidden" data-animate>
  <div class="absolute top-3 left-4 text-6xl text-primary/10 font-serif leading-none">&ldquo;</div>
  <blockquote class="relative z-10 pl-6">
    <p class="text-sm text-foreground/80 leading-relaxed italic mb-3">{randomQuote.text}</p>
    <cite class="text-xs text-muted-foreground/60 not-italic">&mdash; {randomQuote.author}</cite>
  </blockquote>
</div>
