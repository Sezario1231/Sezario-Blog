---
interface Props {
  title: string;
  description?: string;
  url?: string;
}
const { title, description = "", url } = Astro.props;
const siteUrl = Astro.site?.toString().replace(/\/$/, "") || "";
const fullUrl = url ? `${siteUrl}${url}` : siteUrl;
---

<div class="flex items-center gap-2">
  <span class="text-xs text-muted-foreground/60 mr-1">分享</span>
  <a
    href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(fullUrl)}`}
    target="_blank"
    rel="noopener noreferrer"
    class="share-btn p-2 rounded-lg text-muted-foreground/60 hover:text-[#1DA1F2] hover:bg-[#1DA1F2]/10 transition-all duration-200"
    aria-label="分享到 Twitter"
  >
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
    </svg>
  </a>
  <a
    href={`https://service.weibo.com/share/share.php?title=${encodeURIComponent(title)}&url=${encodeURIComponent(fullUrl)}`}
    target="_blank"
    rel="noopener noreferrer"
    class="share-btn p-2 rounded-lg text-muted-foreground/60 hover:text-[#E6162D] hover:bg-[#E6162D]/10 transition-all duration-200"
    aria-label="分享到微博"
  >
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
      <path d="M10.098 20.323c-3.977.391-7.414-1.406-7.672-4.02-.259-2.609 2.759-5.047 6.74-5.441 3.979-.394 7.413 1.404 7.671 4.018.259 2.6-2.759 5.049-6.739 5.443zM20.196 9.4a5.007 5.007 0 00-5.372-1.55l-.253.078a.51.51 0 01-.158.035h-.035a.514.514 0 01-.483-.37l-.016-.054a3.002 3.002 0 00-3.548-1.906l-.073.024a.51.51 0 01-.447-.085.51.51 0 01-.18-.384v-.061A5.003 5.003 0 005.488 8.64l-.252.078a.51.51 0 01-.483-.164.51.51 0 01-.109-.424l.028-.117A7.002 7.002 0 0012.002 15c3.864 0 7-3.136 7-7 0-1.335-.379-2.583-1.034-3.633l-.028-.047a.51.51 0 01.076-.555.51.51 0 01.554-.112l.027.013a6.965 6.965 0 001.528.434z"/>
    </svg>
  </a>
  <a
    href={`https://github.com/Sezario1231`}
    target="_blank"
    rel="noopener noreferrer"
    class="share-btn p-2 rounded-lg text-muted-foreground/60 hover:text-foreground hover:bg-foreground/10 transition-all duration-200"
    aria-label="GitHub"
  >
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
    </svg>
  </a>
  <button
    class="share-btn copy-link-btn p-2 rounded-lg text-muted-foreground/60 hover:text-primary hover:bg-primary/10 transition-all duration-200"
    data-url={fullUrl}
    aria-label="复制链接"
  >
    <svg class="w-4 h-4 link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/>
      <path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/>
    </svg>
    <svg class="w-4 h-4 check-icon hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
      <polyline points="20,6 9,17 4,12"/>
    </svg>
  </button>
</div>

<script>
  document.querySelectorAll(".copy-link-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const url = (btn as HTMLElement).dataset.url || "";
      try {
        await navigator.clipboard.writeText(url);
        const linkIcon = btn.querySelector(".link-icon") as HTMLElement;
        const checkIcon = btn.querySelector(".check-icon") as HTMLElement;
        linkIcon?.classList.add("hidden");
        checkIcon?.classList.remove("hidden");
        btn.classList.add("text-green-400");
        setTimeout(() => {
          linkIcon?.classList.remove("hidden");
          checkIcon?.classList.add("hidden");
          btn.classList.remove("text-green-400");
        }, 2000);
      } catch {}
    });
  });
</script>
