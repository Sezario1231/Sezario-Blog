---
interface Props {
  class?: string;
  lines?: number;
  variant?: "text" | "title" | "avatar" | "card" | "image";
}
const { class: className = "", lines = 3, variant = "text" } = Astro.props;
---

{variant === "card" && (
  <div class:list={["skeleton-card rounded-xl border border-border/40 bg-card/50 p-5 space-y-4", className]}>
    <div class="skeleton-shimmer h-40 rounded-lg bg-muted/50"></div>
    <div class="space-y-2.5">
      <div class="skeleton-shimmer h-3 w-1/3 rounded bg-muted/50"></div>
      <div class="skeleton-shimmer h-5 w-3/4 rounded bg-muted/50"></div>
      <div class="skeleton-shimmer h-3 w-full rounded bg-muted/50"></div>
      <div class="skeleton-shimmer h-3 w-2/3 rounded bg-muted/50"></div>
    </div>
  </div>
)}

{variant === "image" && (
  <div class:list={["skeleton-shimmer rounded-xl bg-muted/50 aspect-video", className]}></div>
)}

{variant === "avatar" && (
  <div class:list={["skeleton-shimmer rounded-full bg-muted/50", className]} style="width: 48px; height: 48px;"></div>
)}

{variant === "title" && (
  <div class:list={["space-y-2.5", className]}>
    <div class="skeleton-shimmer h-8 w-2/3 rounded bg-muted/50"></div>
    <div class="skeleton-shimmer h-4 w-1/3 rounded bg-muted/50"></div>
  </div>
)}

{variant === "text" && (
  <div class:list={["space-y-2.5", className]}>
    {Array.from({ length: lines }).map(() => (
      <div class="skeleton-shimmer h-3.5 rounded bg-muted/50" style={`width: ${70 + Math.random() * 30}%`}></div>
    ))}
  </div>
)}
