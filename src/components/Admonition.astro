---
interface Props {
  type?: "info" | "warning" | "danger" | "success";
  title?: string;
}
const { type = "info", title } = Astro.props;

const config = {
  info: {
    icon: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>`,
    title: title || "提示",
    bg: "bg-blue-500/8 dark:bg-blue-400/8",
    border: "border-blue-500/20 dark:border-blue-400/20",
    text: "text-blue-700 dark:text-blue-300",
    iconColor: "text-blue-500 dark:text-blue-400",
  },
  warning: {
    icon: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>`,
    title: title || "警告",
    bg: "bg-amber-500/8 dark:bg-amber-400/8",
    border: "border-amber-500/20 dark:border-amber-400/20",
    text: "text-amber-700 dark:text-amber-300",
    iconColor: "text-amber-500 dark:text-amber-400",
  },
  danger: {
    icon: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>`,
    title: title || "危险",
    bg: "bg-red-500/8 dark:bg-red-400/8",
    border: "border-red-500/20 dark:border-red-400/20",
    text: "text-red-700 dark:text-red-300",
    iconColor: "text-red-500 dark:text-red-400",
  },
  success: {
    icon: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>`,
    title: title || "成功",
    bg: "bg-green-500/8 dark:bg-green-400/8",
    border: "border-green-500/20 dark:border-green-400/20",
    text: "text-green-700 dark:text-green-300",
    iconColor: "text-green-500 dark:text-green-400",
  },
};

const c = config[type];
---

<div class:list={["admonition rounded-xl border p-4 my-6", c.bg, c.border]}>
  <div class="flex items-center gap-2 mb-2">
    <span class={c.iconColor} set:html={c.icon} />
    <span class:list={["text-sm font-semibold", c.text]}>{c.title}</span>
  </div>
  <div class:list={["text-sm leading-relaxed", c.text, "opacity-90"]}>
    <slot />
  </div>
</div>
