---
interface TimelineItem {
  date: Date;
  title: string;
  slug?: string;
  category?: string;
  description?: string;
}

interface Props {
  items: TimelineItem[];
}

const { items } = Astro.props;

const grouped = items.reduce((acc, item) => {
  const year = item.date.getFullYear().toString();
  if (!acc[year]) acc[year] = [];
  acc[year].push(item);
  return acc;
}, {} as Record<string, TimelineItem[]>);

const years = Object.keys(grouped).sort((a, b) => Number(b) - Number(a));
---

<div class="relative">
  <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-border/50"></div>

  {
    years.map((year, yi) => (
      <div class="mb-16 last:mb-0" data-animate>
        <div class="relative flex justify-center md:justify-start mb-8">
          <span class="relative z-10 inline-flex items-center gap-2 rounded-full bg-primary/10 border border-primary/20 px-4 py-1.5 text-sm font-semibold text-primary">
            {year}
          </span>
        </div>

        <div class="space-y-8">
          {grouped[year].map((item, i) => {
            const isLeft = i % 2 === 0;
            return (
              <div class:list={[
                "relative flex items-start gap-6 md:gap-0",
                isLeft ? "md:flex-row" : "md:flex-row-reverse",
              ]} data-animate style={`animation-delay: ${i * 0.05}s`}>
                <div class="hidden md:block md:w-1/2" />
                <div class="absolute left-4 md:left-1/2 top-2 w-3 h-3 rounded-full bg-primary border-2 border-background -translate-x-1/2 z-10" />
                <div class:list={["md:w-1/2 md:pl-8", isLeft ? "md:pr-8" : "md:pl-8 md:ml-auto"]}>
                  <div class="ml-8 md:ml-0">
                    <time class="text-xs text-muted-foreground">
                      {item.date.toLocaleDateString("zh-CN", { month: "long", day: "numeric" })}
                    </time>
                    {item.slug ? (
                      <a href={`/posts/${item.slug}`} class="block mt-1 group">
                        <h3 class="font-semibold group-hover:text-primary transition-colors duration-200">
                          {item.title}
                        </h3>
                      </a>
                    ) : (
                      <h3 class="font-semibold mt-1">{item.title}</h3>
                    )}
                    {item.description && (
                      <p class="text-sm text-muted-foreground mt-1 line-clamp-2">{item.description}</p>
                    )}
                    {item.category && (
                      <span class="inline-block mt-2 text-[10px] text-primary/80 bg-primary/10 rounded-full px-2 py-0.5">
                        {item.category}
                      </span>
                    )}
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    ))
  }
</div>
