---
interface Item {
  title: string;
  type: "book" | "movie" | "course";
  rating: number; // 1-5
  author?: string;
  status: "done" | "reading" | "watching";
}
interface Props {
  items?: Item[];
}
const { items = [
  { title: "人月神话", type: "book", rating: 5, author: "Frederick P. Brooks", status: "done" },
  { title: "重构", type: "book", rating: 4, author: "Martin Fowler", status: "done" },
  { title: "Designing Data-Intensive Applications", type: "book", rating: 5, author: "Martin Kleppmann", status: "reading" },
  { title: "黑客与画家", type: "book", rating: 4, author: "Paul Graham", status: "done" },
]} = Astro.props;

const typeIcons: Record<string, string> = {
  book: `<svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5v-15A2.5 2.5 0 016.5 2H20v20H6.5a2.5 2.5 0 010-5H20"/></svg>`,
  movie: `<svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/><line x1="2" y1="7" x2="7" y2="7"/><line x1="2" y1="17" x2="7" y2="17"/><line x1="17" y1="17" x2="22" y2="17"/><line x1="17" y1="7" x2="22" y2="7"/></svg>`,
  course: `<svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>`,
};

const statusLabels: Record<string, string> = {
  done: "已读",
  reading: "在读",
  watching: "在看",
};
---

<div class="space-y-2">
  {items.map((item, i) => (
    <div class="reading-item flex items-center gap-3 p-3 rounded-xl border border-border/40 bg-card/50 hover:border-primary/15 transition-all duration-200" data-animate data-delay={i * 50}>
      <div class="shrink-0 w-8 h-8 rounded-lg bg-primary/8 flex items-center justify-center text-primary" set:html={typeIcons[item.type]} />
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2">
          <span class="text-sm font-medium truncate">{item.title}</span>
          <span class:list={[
            "shrink-0 text-[10px] px-1.5 py-0.5 rounded-full",
            item.status === "done" ? "bg-green-500/10 text-green-600 dark:text-green-400" : "bg-amber-500/10 text-amber-600 dark:text-amber-400",
          ]}>{statusLabels[item.status]}</span>
        </div>
        {item.author && <p class="text-xs text-muted-foreground/60 mt-0.5">{item.author}</p>}
      </div>
      <div class="shrink-0 flex gap-0.5">
        {Array.from({ length: 5 }).map((_, j) => (
          <svg class={`w-3 h-3 ${j < item.rating ? "text-amber-400" : "text-muted/30"}`} viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        ))}
      </div>
    </div>
  ))}
</div>
