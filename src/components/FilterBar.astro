---
interface Props {
  categories: string[];
  tags: string[];
  activeCategory?: string;
  activeTag?: string;
}

const { categories, tags, activeCategory, activeTag } = Astro.props;
---

<div class="flex flex-wrap gap-3 items-center" data-animate>
  <div class="flex items-center gap-2">
    <span class="text-xs text-muted-foreground uppercase tracking-wider">分类</span>
    <div class="flex gap-1.5">
      <a
        href="/posts"
        class:list={[
          "px-3 py-1.5 rounded-full text-xs font-medium transition-all duration-200",
          !activeCategory
            ? "bg-primary text-primary-foreground shadow-sm shadow-primary/20"
            : "bg-secondary/60 text-muted-foreground hover:text-foreground hover:bg-secondary",
        ]}
      >
        全部
      </a>
      {
        categories.map((cat) => (
          <a
            href={`/posts?category=${cat}`}
            class:list={[
              "px-3 py-1.5 rounded-full text-xs font-medium transition-all duration-200",
              activeCategory === cat
                ? "bg-primary text-primary-foreground shadow-sm shadow-primary/20"
                : "bg-secondary/60 text-muted-foreground hover:text-foreground hover:bg-secondary",
            ]}
          >
            {cat}
          </a>
        ))
      }
    </div>
  </div>

  {tags.length > 0 && (
    <div class="flex items-center gap-2 mt-3 md:mt-0 md:ml-4 md:border-l md:border-border/50 md:pl-4">
      <span class="text-xs text-muted-foreground uppercase tracking-wider">标签</span>
      <div class="flex flex-wrap gap-1.5">
        {
          tags.map((tag) => (
            <a
              href={`/posts?tag=${tag}`}
              class:list={[
                "px-2.5 py-1 rounded-full text-[10px] font-medium transition-all duration-200",
                activeTag === tag
                  ? "bg-primary/15 text-primary border border-primary/20"
                  : "bg-secondary/40 text-muted-foreground hover:text-foreground hover:bg-secondary",
              ]}
            >
              {tag}
            </a>
          ))
        }
      </div>
    </div>
  )}
</div>
