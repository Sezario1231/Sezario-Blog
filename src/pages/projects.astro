---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectCard from "@/components/ProjectCard";
import { getSupabase } from "@/lib/supabase";

const supabase = getSupabase();
const { data: projectsData } = await supabase
  .from("projects")
  .select("*")
  .order("sort_order", { ascending: true });

interface SupabaseProject {
  id: string;
  name: string;
  description: string;
  tech_stack: string | string[];
  github?: string;
  demo?: string;
  sort_order: number;
}

function parseTechStack(ts: string | string[]): string[] {
  if (Array.isArray(ts)) return ts;
  if (typeof ts === "string") {
    try { return JSON.parse(ts); } catch { return ts.split(",").map((s: string) => s.trim()); }
  }
  return [];
}

const projects = ((projectsData || []) as SupabaseProject[]).map((p) => ({
  name: p.name,
  description: p.description,
  techStack: parseTechStack(p.tech_stack),
  github: p.github,
  demo: p.demo,
}));
---

<BaseLayout title="项目 - Sezario的个人小屋" description="开源项目与技术探索。">
  <section class="container max-w-6xl mx-auto px-5 md:px-8 py-16 md:py-24">
    <div class="mb-14" data-animate>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-3">项目</h1>
      <p class="text-muted-foreground max-w-xl">
        目前开源的项目，持续更新中。
      </p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        projects.map((project, i) => (
          <ProjectCard
            name={project.name}
            description={project.description}
            techStack={project.techStack}
            github={project.github}
            demo={project.demo}
            style={{ animationDelay: `${i * 0.08}s` }}
            data-animate=""
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
