          </div>
          <div class="flex items-center gap-3 pt-2">
            <button type="submit" id="pj-save" class="px-6 py-2.5 rounded-xl bg-primary/80 text-white text-sm font-medium hover:bg-primary/90 transition-colors">保存</button>
            <button type="button" id="pj-cancel" class="px-6 py-2.5 rounded-xl border border-border/40 bg-card/50 text-sm font-medium hover:bg-muted/30 transition-colors">取消</button>
            <span id="pj-loading" class="text-xs text-muted-foreground/60 hidden">保存中...</span>
          </div>
