---
import BaseLayout from "@/layouts/BaseLayout.astro";
import MarkdownEditor from "@/components/admin/MarkdownEditor.tsx";
export const prerender = false;
---

<BaseLayout title="后台管理 - Sezario的个人小屋" description="博客管理面板">
  <!-- 登录界面 -->
  <section id="admin-login" class="container max-w-sm mx-auto px-5 py-32">
    <div class="text-center mb-8">
      <svg class="w-12 h-12 mx-auto text-primary/60 mb-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
      <h1 class="text-2xl font-bold mb-1">后台管理</h1>
      <p class="text-sm text-muted-foreground/60">请输入密码访问</p>
    </div>
    <form id="login-form" class="space-y-4">
      <input type="password" id="login-password" placeholder="输入管理密码"
        class="w-full px-4 py-3 rounded-xl border border-border/40 bg-card/50 text-sm focus:outline-none focus:border-primary/40 transition-colors"
        autocomplete="current-password" />
      <p id="login-error" class="text-xs text-red-500 hidden">密码错误，请重试</p>
      <button type="submit" id="login-btn" class="w-full px-4 py-3 rounded-xl bg-primary/80 text-white text-sm font-medium hover:bg-primary/90 transition-colors">
        进入管理面板
      </button>
    </form>
  </section>

  <!-- 管理面板 -->
  <section id="admin-panel" class="container max-w-6xl mx-auto px-5 md:px-8 py-12 md:py-16 hidden">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-3xl md:text-4xl font-bold tracking-tight mb-2">后台管理</h1>
        <p class="text-sm text-muted-foreground/60">管理站点内容、外观和数据</p>
      </div>
      <button id="logout-btn" class="px-4 py-2 rounded-xl border border-border/40 bg-card/50 text-sm text-muted-foreground/60 hover:text-red-500 hover:border-red-500/20 transition-all">退出</button>
    </div>

    <!-- 标签导航 -->
    <div class="flex gap-1 mb-8 overflow-x-auto pb-2 border-b border-border/30" id="admin-tabs">
      <button class="tab-btn px-4 py-2 rounded-lg text-sm font-medium whitespace-nowrap bg-primary/10 text-primary" data-tab="dashboard">数据看板</button>
      <button class="tab-btn px-4 py-2 rounded-lg text-sm font-medium whitespace-nowrap text-muted-foreground/60 hover:bg-muted/30" data-tab="posts">文章管理</button>
      <button class="tab-btn px-4 py-2 rounded-lg text-sm font-medium whitespace-nowrap text-muted-foreground/60 hover:bg-muted/30" data-tab="projects">项目管理</button>
      <button class="tab-btn px-4 py-2 rounded-lg text-sm font-medium whitespace-nowrap text-muted-foreground/60 hover:bg-muted/30" data-tab="quotes">名言管理</button>
      <button class="tab-btn px-4 py-2 rounded-lg text-sm font-medium whitespace-nowrap text-muted-foreground/60 hover:bg-muted/30" data-tab="settings">站点设置</button>
      <button class="tab-btn px-4 py-2 rounded-lg text-sm font-medium whitespace-nowrap text-muted-foreground/60 hover:bg-muted/30" data-tab="contacts">留言管理</button>
      <button class="tab-btn px-4 py-2 rounded-lg text-sm font-medium whitespace-nowrap text-muted-foreground/60 hover:bg-muted/30" data-tab="comments">评论管理</button>
      <button class="tab-btn px-4 py-2 rounded-lg text-sm font-medium whitespace-nowrap text-muted-foreground/60 hover:bg-muted/30" data-tab="export">数据导出</button>
      <button class="tab-btn px-4 py-2 rounded-lg text-sm font-medium whitespace-nowrap text-muted-foreground/60 hover:bg-muted/30" data-tab="plugins">插件管理</button>
      <button class="tab-btn px-4 py-2 rounded-lg text-sm font-medium whitespace-nowrap text-muted-foreground/60 hover:bg-muted/30" data-tab="appearance">主题外观</button>
    </div>

    <!-- ===== 数据看板 ===== -->
    <div class="tab-panel" id="panel-dashboard">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
        <div class="p-5 rounded-xl border border-border/40 bg-card/50">
          <p class="text-xs text-muted-foreground/60 mb-1">已发布文章</p>
          <p class="text-2xl font-bold text-primary" id="stat-published">-</p>
        </div>
        <div class="p-5 rounded-xl border border-border/40 bg-card/50">
          <p class="text-xs text-muted-foreground/60 mb-1">草稿</p>
          <p class="text-2xl font-bold text-orange-400" id="stat-drafts">-</p>
        </div>
        <div class="p-5 rounded-xl border border-border/40 bg-card/50">
          <p class="text-xs text-muted-foreground/60 mb-1">项目</p>
          <p class="text-2xl font-bold text-emerald-500" id="stat-projects">-</p>
        </div>
        <div class="p-5 rounded-xl border border-border/40 bg-card/50">
          <p class="text-xs text-muted-foreground/60 mb-1">名言</p>
          <p class="text-2xl font-bold text-yellow-500" id="stat-quotes">-</p>
        </div>
        <div class="p-5 rounded-xl border border-border/40 bg-card/50">
          <p class="text-xs text-muted-foreground/60 mb-1">留言</p>
          <p class="text-2xl font-bold text-sky-500" id="stat-contacts">-</p>
        </div>
        <div class="p-5 rounded-xl border border-border/40 bg-card/50">
          <p class="text-xs text-muted-foreground/60 mb-1">未读留言</p>
          <p class="text-2xl font-bold text-red-500" id="stat-unread">-</p>
        </div>
        <div class="p-5 rounded-xl border border-border/40 bg-card/50">
          <p class="text-xs text-muted-foreground/60 mb-1">评论</p>
          <p class="text-2xl font-bold text-violet-500" id="stat-comments">-</p>
        </div>
        <div class="p-5 rounded-xl border border-border/40 bg-card/50">
          <p class="text-xs text-muted-foreground/60 mb-1">在线访客</p>
          <p class="text-2xl font-bold text-cyan-500" id="stat-visitors">-</p>
        </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="p-5 rounded-xl border border-border/40 bg-card/50">
          <h3 class="text-sm font-semibold mb-3">最新文章</h3>
          <div id="recent-posts" class="space-y-2">
            <p class="text-xs text-muted-foreground/40">加载中...</p>
          </div>
        </div>
        <div class="p-5 rounded-xl border border-border/40 bg-card/50">
          <h3 class="text-sm font-semibold mb-3">最新评论</h3>
          <div id="recent-comments" class="space-y-2">
            <p class="text-xs text-muted-foreground/40">加载中...</p>
          </div>
        </div>
      </div>
    </div>

    <!-- ===== 文章管理 ===== -->
    <div class="tab-panel hidden" id="panel-posts">
      <div class="flex items-center gap-3 mb-4">
        <input type="text" id="post-search" placeholder="搜索文章标题..." class="flex-1 px-4 py-2 rounded-xl border border-border/40 bg-card/50 text-sm focus:outline-none focus:border-primary/40" />
        <select id="post-status-filter" class="px-3 py-2 rounded-xl border border-border/40 bg-card/50 text-sm focus:outline-none">
          <option value="">全部状态</option>
          <option value="published">已发布</option>
          <option value="draft">草稿</option>
        </select>
        <button id="btn-new-post" class="px-4 py-2 rounded-xl bg-primary/80 text-white text-sm font-medium hover:bg-primary/90 transition-colors whitespace-nowrap">新建文章</button>
      </div>
      <div class="border border-border/40 rounded-xl overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-muted/30 border-b border-border/40">
              <th class="w-10 px-2 py-3"><input type="checkbox" id="posts-select-all" class="rounded border-border/40 accent-primary" /></th>
              <th class="text-left px-4 py-3 font-medium text-muted-foreground/70">标题</th>
              <th class="text-left px-4 py-3 font-medium text-muted-foreground/70 hidden sm:table-cell">分类</th>
              <th class="text-left px-4 py-3 font-medium text-muted-foreground/70 hidden md:table-cell">状态</th>
              <th class="text-left px-4 py-3 font-medium text-muted-foreground/70 hidden md:table-cell">日期</th>
              <th class="text-right px-4 py-3 font-medium text-muted-foreground/70 pr-2">操作</th>
            </tr>
          </thead>
          <tbody id="posts-tbody">
            <tr><td colspan="6" class="px-4 py-8 text-center text-sm text-muted-foreground/40">加载中...</td></tr>
          </tbody>
        </table>
      </div>
      <div id="posts-batch-bar" class="flex items-center gap-2 mt-3 hidden">
        <span class="text-xs text-muted-foreground/60 mr-1" id="posts-selected-count">已选 0 项</span>
        <button class="px-3 py-1.5 rounded-lg bg-red-500/80 text-white text-xs font-medium hover:bg-red-500 transition-colors batch-btn" data-type="posts" data-action="delete">批量删除</button>
        <button class="px-3 py-1.5 rounded-lg bg-emerald-500/80 text-white text-xs font-medium hover:bg-emerald-500 transition-colors batch-btn" data-type="posts" data-action="publish">批量发布</button>
        <button class="px-3 py-1.5 rounded-lg bg-orange-400/80 text-white text-xs font-medium hover:bg-orange-400 transition-colors batch-btn" data-type="posts" data-action="draft">标记草稿</button>
      </div>
      <p class="text-xs text-muted-foreground/40 mt-3" id="post-count"></p>
    </div>

    <!-- ===== 项目管理 ===== -->
    <div class="tab-panel hidden" id="panel-projects">
      <div class="flex items-center gap-3 mb-4">
        <input type="text" id="project-search" placeholder="搜索项目名称..." class="flex-1 px-4 py-2 rounded-xl border border-border/40 bg-card/50 text-sm focus:outline-none focus:border-primary/40" />
        <button id="btn-new-project" class="px-4 py-2 rounded-xl bg-primary/80 text-white text-sm font-medium hover:bg-primary/90 transition-colors whitespace-nowrap">新建项目</button>
      </div>
      <div class="border border-border/40 rounded-xl overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-muted/30 border-b border-border/40">
              <th class="w-10 px-2 py-3"><input type="checkbox" id="projects-select-all" class="rounded border-border/40 accent-primary" /></th>
              <th class="text-left px-4 py-3 font-medium text-muted-foreground/70">名称</th>
              <th class="text-left px-4 py-3 font-medium text-muted-foreground/70 hidden sm:table-cell">技术栈</th>
              <th class="text-left px-4 py-3 font-medium text-muted-foreground/70 hidden md:table-cell">GitHub</th>
              <th class="text-right px-4 py-3 font-medium text-muted-foreground/70 pr-2">操作</th>
            </tr>
          </thead>
          <tbody id="projects-tbody">
            <tr><td colspan="5" class="px-4 py-8 text-center text-sm text-muted-foreground/40">加载中...</td></tr>
          </tbody>
        </table>
      </div>
      <div id="projects-batch-bar" class="flex items-center gap-2 mt-3 hidden">
        <span class="text-xs text-muted-foreground/60 mr-1" id="projects-selected-count">已选 0 项</span>
        <button class="px-3 py-1.5 rounded-lg bg-red-500/80 text-white text-xs font-medium hover:bg-red-500 transition-colors batch-btn" data-type="projects" data-action="delete">批量删除</button>
      </div>
    </div>

    <!-- ===== 名言管理 ===== -->
    <div class="tab-panel hidden" id="panel-quotes">
      <div class="flex items-center gap-3 mb-4">
        <input type="text" id="quote-search" placeholder="搜索名言..." class="flex-1 px-4 py-2 rounded-xl border border-border/40 bg-card/50 text-sm focus:outline-none focus:border-primary/40" />
        <button id="btn-new-quote" class="px-4 py-2 rounded-xl bg-primary/80 text-white text-sm font-medium hover:bg-primary/90 transition-colors whitespace-nowrap">添加名言</button>
      </div>
      <div class="border border-border/40 rounded-xl overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-muted/30 border-b border-border/40">
              <th class="w-10 px-2 py-3"><input type="checkbox" id="quotes-select-all" class="rounded border-border/40 accent-primary" /></th>
              <th class="text-left px-4 py-3 font-medium text-muted-foreground/70">内容</th>
              <th class="text-left px-4 py-3 font-medium text-muted-foreground/70 hidden sm:table-cell">作者</th>
              <th class="text-right px-4 py-3 font-medium text-muted-foreground/70 pr-2">操作</th>
            </tr>
          </thead>
          <tbody id="quotes-tbody">
            <tr><td colspan="4" class="px-4 py-8 text-center text-sm text-muted-foreground/40">加载中...</td></tr>
          </tbody>
        </table>
      </div>
      <div id="quotes-batch-bar" class="flex items-center gap-2 mt-3 hidden">
        <span class="text-xs text-muted-foreground/60 mr-1" id="quotes-selected-count">已选 0 项</span>
        <button class="px-3 py-1.5 rounded-lg bg-red-500/80 text-white text-xs font-medium hover:bg-red-500 transition-colors batch-btn" data-type="quotes" data-action="delete">批量删除</button>
      </div>
    </div>

    <!-- ===== 站点设置 ===== -->
    <div class="tab-panel hidden" id="panel-settings">
      <div class="max-w-lg space-y-4">
        <div>
          <label class="text-sm font-medium block mb-1.5">站点标题</label>
          <input type="text" id="set-site_title" class="w-full px-4 py-2.5 rounded-xl border border-border/40 bg-card/50 text-sm focus:outline-none focus:border-primary/40" />
        </div>
        <div>
          <label class="text-sm font-medium block mb-1.5">站点描述</label>
          <input type="text" id="set-site_description" class="w-full px-4 py-2.5 rounded-xl border border-border/40 bg-card/50 text-sm focus:outline-none focus:border-primary/40" />
        </div>
        <div>
          <label class="text-sm font-medium block mb-1.5">站点标语</label>
          <input type="text" id="set-site_tagline" class="w-full px-4 py-2.5 rounded-xl border border-border/40 bg-card/50 text-sm focus:outline-none focus:border-primary/40" />
        </div>
        <div>
          <label class="text-sm font-medium block mb-1.5">头像 URL</label>
          <input type="text" id="set-avatar_url" class="w-full px-4 py-2.5 rounded-xl border border-border/40 bg-card/50 text-sm focus:outline-none focus:border-primary/40" />
        </div>
        <div>
          <label class="text-sm font-medium block mb-1.5">Hero 标题</label>
          <input type="text" id="set-hero_title" class="w-full px-4 py-2.5 rounded-xl border border-border/40 bg-card/50 text-sm focus:outline-none focus:border-primary/40" />
        </div>
        <div>
          <label class="text-sm font-medium block mb-1.5">Hero 副标题</label>
          <input type="text" id="set-hero_subtitle" class="w-full px-4 py-2.5 rounded-xl border border-border/40 bg-card/50 text-sm focus:outline-none focus:border-primary/40" />
        </div>
        <div>
          <label class="text-sm font-medium block mb-1.5">Hero 标语</label>
          <input type="text" id="set-hero_tagline" class="w-full px-4 py-2.5 rounded-xl border border-border/40 bg-card/50 text-sm focus:outline-none focus:border-primary/40" />
        </div>
        <div>
          <label class="text-sm font-medium block mb-1.5">Hero 技术栈（逗号分隔）</label>
          <input type="text" id="set-hero_tech_stack" class="w-full px-4 py-2.5 rounded-xl border border-border/40 bg-card/50 text-sm focus:outline-none focus:border-primary/40" />
        </div>
        <div>
          <label class="text-sm font-medium block mb-1.5">关于页简介（每行一段）</label>
          <textarea id="set-about_bio" rows="5" class="w-full px-4 py-2.5 rounded-xl border border-border/40 bg-card/50 text-sm focus:outline-none focus:border-primary/40 resize-y"></textarea>
        </div>
        <div>
          <label class="text-sm font-medium block mb-1.5">关于页技术栈（逗号分隔）</label>
          <input type="text" id="set-about_tech_stack" class="w-full px-4 py-2.5 rounded-xl border border-border/40 bg-card/50 text-sm focus:outline-none focus:border-primary/40" />
        </div>
        <div>
          <label class="text-sm font-medium block mb-1.5">页脚邮箱</label>
          <input type="text" id="set-footer_email" class="w-full px-4 py-2.5 rounded-xl border border-border/40 bg-card/50 text-sm focus:outline-none focus:border-primary/40" />
        </div>
        <div>
          <label class="text-sm font-medium block mb-1.5">GitHub 链接</label>
          <input type="text" id="set-github_url" class="w-full px-4 py-2.5 rounded-xl border border-border/40 bg-card/50 text-sm focus:outline-none focus:border-primary/40" />
        </div>
        <div>
          <label class="text-sm font-medium block mb-1.5">Twitter 链接</label>
          <input type="text" id="set-twitter_url" class="w-full px-4 py-2.5 rounded-xl border border-border/40 bg-card/50 text-sm focus:outline-none focus:border-primary/40" />
        </div>
        <button id="save-settings" class="px-6 py-2.5 rounded-xl bg-primary/80 text-white text-sm font-medium hover:bg-primary/90 transition-colors">保存设置</button>
        <p id="settings-saved" class="text-xs text-green-500 hidden">已保存</p>
      </div>
    </div>

    <!-- ===== 留言管理 ===== -->
    <div class="tab-panel hidden" id="panel-contacts">
      <div class="flex items-center gap-3 mb-4">
        <input type="text" id="contact-search" placeholder="搜索姓名或邮箱..." class="flex-1 px-4 py-2 rounded-xl border border-border/40 bg-card/50 text-sm focus:outline-none focus:border-primary/40" />
        <select id="contact-status-filter" class="px-3 py-2 rounded-xl border border-border/40 bg-card/50 text-sm focus:outline-none">
          <option value="">全部</option>
          <option value="unread">未读</option>
        </select>
      </div>
      <div class="border border-border/40 rounded-xl overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-muted/30 border-b border-border/40">
              <th class="w-10 px-2 py-3"><input type="checkbox" id="contacts-select-all" class="rounded border-border/40 accent-primary" /></th>
              <th class="text-left px-4 py-3 font-medium text-muted-foreground/70">姓名</th>
              <th class="text-left px-4 py-3 font-medium text-muted-foreground/70 hidden sm:table-cell">邮箱</th>
              <th class="text-left px-4 py-3 font-medium text-muted-foreground/70 hidden md:table-cell">内容</th>
              <th class="text-left px-4 py-3 font-medium text-muted-foreground/70 hidden md:table-cell">日期</th>
              <th class="text-right px-4 py-3 font-medium text-muted-foreground/70 pr-2">操作</th>
            </tr>
          </thead>
          <tbody id="contacts-tbody">
            <tr><td colspan="6" class="px-4 py-8 text-center text-sm text-muted-foreground/40">加载中...</td></tr>
          </tbody>
        </table>
      </div>
      <div id="contacts-batch-bar" class="flex items-center gap-2 mt-3 hidden">
        <span class="text-xs text-muted-foreground/60 mr-1" id="contacts-selected-count">已选 0 项</span>
        <button class="px-3 py-1.5 rounded-lg bg-red-500/80 text-white text-xs font-medium hover:bg-red-500 transition-colors batch-btn" data-type="contacts" data-action="delete">批量删除</button>
        <button class="px-3 py-1.5 rounded-lg bg-primary/80 text-white text-xs font-medium hover:bg-primary/90 transition-colors batch-btn" data-type="contacts" data-action="read">标记已读</button>
      </div>
      <div class="flex items-center justify-between mt-3">
        <p class="text-xs text-muted-foreground/40" id="contact-count"></p>
        <div class="flex gap-2" id="contact-pagination">
          <button id="contact-prev" class="px-3 py-1 rounded-lg border border-border/40 text-xs text-muted-foreground/60 hover:text-primary disabled:opacity-30 disabled:cursor-not-allowed" disabled>上一页</button>
          <button id="contact-next" class="px-3 py-1 rounded-lg border border-border/40 text-xs text-muted-foreground/60 hover:text-primary disabled:opacity-30 disabled:cursor-not-allowed" disabled>下一页</button>
        </div>
      </div>
    </div>

    <!-- ===== 评论管理 ===== -->
    <div class="tab-panel hidden" id="panel-comments">
      <div class="border border-border/40 rounded-xl overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-muted/30 border-b border-border/40">
              <th class="w-10 px-2 py-3"><input type="checkbox" id="comments-select-all" class="rounded border-border/40 accent-primary" /></th>
              <th class="text-left px-4 py-3 font-medium text-muted-foreground/70">作者</th>
              <th class="text-left px-4 py-3 font-medium text-muted-foreground/70 hidden sm:table-cell">内容</th>
              <th class="text-left px-4 py-3 font-medium text-muted-foreground/70 hidden md:table-cell">文章</th>
              <th class="text-left px-4 py-3 font-medium text-muted-foreground/70 hidden md:table-cell">日期</th>
              <th class="text-right px-4 py-3 font-medium text-muted-foreground/70 pr-2">操作</th>
            </tr>
          </thead>
          <tbody id="comments-tbody">
            <tr><td colspan="6" class="px-4 py-8 text-center text-sm text-muted-foreground/40">加载中...</td></tr>
          </tbody>
        </table>
      </div>
      <div id="comments-batch-bar" class="flex items-center gap-2 mt-3 hidden">
        <span class="text-xs text-muted-foreground/60 mr-1" id="comments-selected-count">已选 0 项</span>
        <button class="px-3 py-1.5 rounded-lg bg-red-500/80 text-white text-xs font-medium hover:bg-red-500 transition-colors batch-btn" data-type="comments" data-action="delete">批量删除</button>
      </div>
      <div class="flex items-center justify-between mt-3">
        <p class="text-xs text-muted-foreground/40" id="comment-count"></p>
        <div class="flex gap-2" id="comment-pagination">
          <button id="comment-prev" class="px-3 py-1 rounded-lg border border-border/40 text-xs text-muted-foreground/60 hover:text-primary disabled:opacity-30 disabled:cursor-not-allowed" disabled>上一页</button>
          <button id="comment-next" class="px-3 py-1 rounded-lg border border-border/40 text-xs text-muted-foreground/60 hover:text-primary disabled:opacity-30 disabled:cursor-not-allowed" disabled>下一页</button>
