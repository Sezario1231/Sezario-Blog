  // ===== Batch Operations =====
  function setupBatchSelectAll(selectAllId: string, checkboxClass: string, batchBarId: string, countId: string) {
    const selectAll = document.getElementById(selectAllId) as HTMLInputElement;
    const batchBar = document.getElementById(batchBarId);
    const countEl = document.getElementById(countId);
    if (!selectAll || !batchBar || !countEl) return;

    function updateBatchBar() {
      const tbody = selectAll.closest("table")?.querySelector("tbody");
      if (!tbody) return;
      const checked = tbody.querySelectorAll<HTMLInputElement>(`.${checkboxClass}:checked`);
      const total = tbody.querySelectorAll<HTMLInputElement>(`.${checkboxClass}`).length;
      countEl.textContent = `已选 ${checked.length} 项`;
      batchBar.classList.toggle("hidden", checked.length === 0);
      if (selectAll) selectAll.checked = checked.length > 0 && checked.length === total;
    }

    selectAll.addEventListener("change", () => {
      const tbody = selectAll.closest("table")?.querySelector("tbody");
      if (!tbody) return;
      tbody.querySelectorAll<HTMLInputElement>(`.${checkboxClass}`).forEach((cb) => { cb.checked = selectAll.checked; });
      updateBatchBar();
    });

    document.addEventListener("change", (e) => {
      const target = e.target as HTMLElement;
      if (target.classList.contains(checkboxClass)) updateBatchBar();
    });

    const observer = new MutationObserver(() => {
      const tbody = selectAll.closest("table")?.querySelector("tbody");
      if (!tbody) return;
      tbody.querySelectorAll<HTMLInputElement>(`.${checkboxClass}`).forEach((cb) => {
        cb.removeEventListener("change", updateBatchBar);
        cb.addEventListener("change", updateBatchBar);
      });
      updateBatchBar();
    });
    const table = selectAll.closest("table");
    if (table) observer.observe(table, { childList: true, subtree: true });
  }

  setupBatchSelectAll("posts-select-all", "posts-checkbox", "posts-batch-bar", "posts-selected-count");
  setupBatchSelectAll("projects-select-all", "projects-checkbox", "projects-batch-bar", "projects-selected-count");
  setupBatchSelectAll("quotes-select-all", "quotes-checkbox", "quotes-batch-bar", "quotes-selected-count");
  setupBatchSelectAll("contacts-select-all", "contacts-checkbox", "contacts-batch-bar", "contacts-selected-count");
  setupBatchSelectAll("comments-select-all", "comments-checkbox", "comments-batch-bar", "comments-selected-count");

  document.querySelectorAll(".batch-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const el = btn as HTMLElement;
      const type = el.dataset.type!;
      const action = el.dataset.action!;
      const checkboxClass = `${type}-checkbox`;
      const checkedBoxes = document.querySelectorAll<HTMLInputElement>(`.${checkboxClass}:checked`);
      const ids = Array.from(checkedBoxes).map((cb) => cb.value);
      if (ids.length === 0) return;

      const actionLabel = action === "delete" ? "删除" : action === "publish" ? "发布" : action === "draft" ? "标记草稿" : action === "read" ? "标记已读" : action;
      if (!confirm(`确定${actionLabel}选中的 ${ids.length} 项？`)) return;

      el.textContent = "操作中...";
      (el as HTMLButtonElement).disabled = true;
      try {
        await apiPost(`/api/admin/${type}/batch`, { action, ids });
        // reload the relevant data
        if (type === "posts") await loadPosts();
        else if (type === "projects") await loadProjects();
        else if (type === "quotes") await loadQuotes();
        else if (type === "contacts") await loadContacts();
        else if (type === "comments") await loadCommentsAdmin();
      } catch (e: any) {
        alert(`批量操作失败: ${e.message}`);
      } finally {
        el.textContent = actionLabel === "标记草稿" ? "标记草稿" : actionLabel === "标记已读" ? "标记已读" : `批量${actionLabel}`;
        (el as HTMLButtonElement).disabled = false;
      }
    });
  });

  // ===== Data Export =====
  document.querySelectorAll(".export-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const type = (btn as HTMLElement).dataset.type;
      const token = sessionStorage.getItem(PASSWORD_KEY) || "";
      window.open(`/api/admin/export/${type}?x-admin-password=${encodeURIComponent(token)}`, "_blank");
    });
  });

  // ===== Tab load hooks =====
  document.querySelector('[data-tab="contacts"]')?.addEventListener("click", () => { contactPage = 1; loadContacts(); }, true);
  document.querySelector('[data-tab="comments"]')?.addEventListener("click", () => { commentPage = 1; loadCommentsAdmin(); }, true);

  // ===== Contact View Modal =====
  const cvOverlay = document.createElement("div");
  cvOverlay.id = "contact-view-overlay";
  cvOverlay.className = "fixed inset-0 z-50 bg-black/50 backdrop-blur-sm hidden items-center justify-center p-4";
  cvOverlay.innerHTML = `
    <div class="bg-card border border-border/40 rounded-2xl w-full max-w-lg shadow-2xl">
      <div class="flex items-center justify-between px-6 py-4 border-b border-border/30">
        <h2 class="text-lg font-bold">留言详情</h2>
        <button id="cv-close" class="text-muted-foreground/60 hover:text-primary transition-colors">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="p-6 space-y-4">
        <div class="flex items-center gap-4">
          <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold text-sm" id="cv-avatar"></div>
          <div>
            <p class="font-medium text-sm" id="cv-name"></p>
            <p class="text-xs text-muted-foreground/60" id="cv-email"></p>
          </div>
          <div class="ml-auto text-xs text-muted-foreground/40" id="cv-date"></div>
        </div>
        <div class="p-4 rounded-xl bg-muted/20 border border-border/20">
          <p class="text-sm whitespace-pre-wrap" id="cv-message"></p>
        </div>
        <div class="flex justify-end gap-2 pt-2">
          <button id="cv-delete" class="px-4 py-2 rounded-xl bg-red-500/80 text-white text-xs font-medium hover:bg-red-500 transition-colors">删除留言</button>
          <button id="cv-close-btn" class="px-4 py-2 rounded-xl border border-border/40 text-xs font-medium hover:bg-muted/30 transition-colors">关闭</button>
        </div>
      </div>
    </div>`;
  document.body.appendChild(cvOverlay);

  document.getElementById("cv-close")?.addEventListener("click", () => { cvOverlay.classList.add("hidden"); cvOverlay.classList.remove("flex"); });
  document.getElementById("cv-close-btn")?.addEventListener("click", () => { cvOverlay.classList.add("hidden"); cvOverlay.classList.remove("flex"); });
  cvOverlay.addEventListener("click", (e) => { if (e.target === e.currentTarget) { cvOverlay.classList.add("hidden"); cvOverlay.classList.remove("flex"); } });
  document.getElementById("cv-delete")?.addEventListener("click", () => {
    if (currentContactId) deleteContact(currentContactId);
  });

  // ===== Plugins (localStorage) =====
  document.querySelectorAll<HTMLInputElement>(".plugin-toggle input").forEach((toggle) => {
    const plugin = toggle.dataset.plugin || "";
    const stored = localStorage.getItem(`plugin_${plugin}`);
    toggle.checked = stored !== "off";

    toggle.addEventListener("change", () => {
      localStorage.setItem(`plugin_${plugin}`, toggle.checked ? "on" : "off");
      if (plugin === "liteMode") {
        document.documentElement.classList.toggle("lite-mode", toggle.checked);
        if (toggle.checked) {
          document.querySelectorAll<HTMLInputElement>(".plugin-toggle input").forEach((t) => {
            if (t.dataset.plugin !== "liteMode") { t.checked = false; localStorage.setItem(`plugin_${t.dataset.plugin}`, "off"); }
          });
        }
      }
      if (plugin === "particles") document.querySelectorAll("canvas").forEach((c) => (c as HTMLElement).style.display = toggle.checked ? "" : "none");
      if (plugin === "scrollReveal") document.querySelectorAll("[data-animate]").forEach((el) => { (el as HTMLElement).style.animationPlayState = toggle.checked ? "running" : "paused"; });
      if (plugin === "cosmicEnding") { const e = document.getElementById("cosmic-ending"); if (e) e.style.display = toggle.checked ? "" : "none"; }
      if (plugin === "magneticButtons") document.documentElement.classList.toggle("no-magnetic", !toggle.checked);
      if (plugin === "textScramble") document.documentElement.classList.toggle("no-scramble", !toggle.checked);
      if (plugin === "cardTilt") document.documentElement.classList.toggle("no-tilt", !toggle.checked);
    });
  });

  if (localStorage.getItem("plugin_liteMode") === "on") document.documentElement.classList.add("lite-mode");

  // ===== Appearance (localStorage) =====
  function loadAppearanceState() {
    const theme = localStorage.getItem("theme") || "dark";
    const el = document.getElementById("current-theme");
    if (el) el.textContent = ({ light: "日间暖光", dark: "极客蓝", "deep-blue": "深夜蓝", "eye-green": "护眼绿" } as Record<string, string>)[theme] || theme;
    const fs = document.getElementById("current-font");
    if (fs) fs.textContent = document.documentElement.classList.contains("large-font") ? "大字号" : "标准";
    const lite = document.getElementById("current-lite");
    if (lite) lite.textContent = document.documentElement.classList.contains("lite-mode") ? "开启" : "关闭";
  }

  document.querySelectorAll(".theme-opt").forEach((btn) => {
    btn.addEventListener("click", () => {
      const theme = (btn as HTMLElement).dataset.theme!;
      localStorage.setItem("theme", theme);
      document.documentElement.setAttribute("data-theme", theme);
      loadAppearanceState();
    });
  });

  document.getElementById("clear-theme")?.addEventListener("click", () => {
    localStorage.removeItem("theme");
    document.documentElement.removeAttribute("data-theme");
    loadAppearanceState();
  });

  document.getElementById("toggle-font-size")?.addEventListener("click", () => {
    document.documentElement.classList.toggle("large-font");
    loadAppearanceState();
  });

  loadAppearanceState();
</script>
