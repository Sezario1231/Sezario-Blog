    <!-- ===== 名言编辑器 Modal ===== -->
    <div id="quote-editor-overlay" class="fixed inset-0 z-50 bg-black/50 backdrop-blur-sm hidden items-center justify-center p-4">
      <div class="bg-card border border-border/40 rounded-2xl w-full max-w-md shadow-2xl">
        <div class="flex items-center justify-between px-6 py-4 border-b border-border/30">
          <h2 class="text-lg font-bold">添加名言</h2>
          <button id="quote-editor-close" class="text-muted-foreground/60 hover:text-primary transition-colors">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
          </button>
        </div>
        <form id="quote-editor-form" class="p-6 space-y-4">
          <div>
            <label class="text-sm font-medium block mb-1.5">名言内容 *</label>
            <textarea id="q-text" rows="3" required class="w-full px-4 py-2.5 rounded-xl border border-border/40 bg-card/50 text-sm focus:outline-none focus:border-primary/40 resize-y"></textarea>
          </div>
          <div>
            <label class="text-sm font-medium block mb-1.5">作者</label>
            <input type="text" id="q-author" placeholder="Unknown" class="w-full px-4 py-2.5 rounded-xl border border-border/40 bg-card/50 text-sm focus:outline-none focus:border-primary/40" />
          </div>
          <div class="flex items-center gap-3 pt-2">
            <button type="submit" id="q-save" class="px-6 py-2.5 rounded-xl bg-primary/80 text-white text-sm font-medium hover:bg-primary/90 transition-colors">保存</button>
            <button type="button" id="q-cancel" class="px-6 py-2.5 rounded-xl border border-border/40 bg-card/50 text-sm font-medium hover:bg-muted/30 transition-colors">取消</button>
            <span id="q-loading" class="text-xs text-muted-foreground/60 hidden">保存中...</span>
          </div>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const PASSWORD_KEY = "admin_password";

  function getAuthHeaders(): Record<string, string> {
    const pwd = sessionStorage.getItem(PASSWORD_KEY) || "";
    return { "x-admin-password": pwd };
  }

  async function apiFetch(url: string, opts: RequestInit = {}): Promise<Response> {
    const headers = { ...getAuthHeaders(), ...opts.headers };
    return fetch(url, { ...opts, headers });
  }

  async function apiGet(url: string) {
    const res = await apiFetch(url);
    if (!res.ok) throw new Error(`API error: ${res.status}`);
    return res.json();
  }

  async function apiPost(url: string, body: any) {
    const res = await apiFetch(url, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(body),
    });
    if (!res.ok) {
      const e = await res.json().catch(() => ({}));
      throw new Error(e.error || `API error: ${res.status}`);
    }
    return res.json();
  }

  async function apiPut(url: string, body: any) {
    const res = await apiFetch(url, {
      method: "PUT",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(body),
    });
    if (!res.ok) {
      const e = await res.json().catch(() => ({}));
      throw new Error(e.error || `API error: ${res.status}`);
    }
    return res.json();
  }

  async function apiDelete(url: string, body?: any) {
    const opts: RequestInit = { method: "DELETE" };
    if (body) {
      opts.headers = { "Content-Type": "application/json" };
      opts.body = JSON.stringify(body);
    }
    const res = await apiFetch(url, opts);
    if (!res.ok) {
      const e = await res.json().catch(() => ({}));
      throw new Error(e.error || `API error: ${res.status}`);
    }
    return res.json();
  }

  function esc(str: string) {
    const d = document.createElement("div");
    d.textContent = str;
    return d.innerHTML;
  }

  // ===== Login =====
  const loginForm = document.getElementById("login-form") as HTMLFormElement;
  const loginPanel = document.getElementById("admin-panel");
  const loginSection = document.getElementById("admin-login");
  const loginError = document.getElementById("login-error");

  async function showAdmin() {
    loginSection?.classList.add("hidden");
    loginPanel?.classList.remove("hidden");
    loadAllData();
  }

  if (sessionStorage.getItem(PASSWORD_KEY)) showAdmin();

  loginForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const pwd = (document.getElementById("login-password") as HTMLInputElement).value;
    const btn = document.getElementById("login-btn") as HTMLButtonElement;
    btn.textContent = "验证中...";
    btn.disabled = true;
    try {
      const res = await fetch("/api/admin-verify", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ password: pwd }),
      });
      if (res.ok) {
        sessionStorage.setItem(PASSWORD_KEY, pwd);
        showAdmin();
      } else {
        loginError?.classList.remove("hidden");
        setTimeout(() => loginError?.classList.add("hidden"), 2000);
      }
    } catch {
      loginError?.classList.remove("hidden");
      setTimeout(() => loginError?.classList.add("hidden"), 2000);
    } finally {
      btn.textContent = "进入管理面板";
      btn.disabled = false;
    }
  });

  document.getElementById("logout-btn")?.addEventListener("click", () => {
    sessionStorage.removeItem(PASSWORD_KEY);
    location.reload();
  });

  // ===== Tab Switching =====
  const tabBtns = document.querySelectorAll<HTMLButtonElement>(".tab-btn");
  const tabPanels = document.querySelectorAll<HTMLElement>(".tab-panel");

  tabBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      tabBtns.forEach((b) => { b.classList.remove("bg-primary/10", "text-primary"); b.classList.add("text-muted-foreground/60"); });
      tabPanels.forEach((p) => p.classList.add("hidden"));
      btn.classList.add("bg-primary/10", "text-primary");
      btn.classList.remove("text-muted-foreground/60");
      document.getElementById(`panel-${btn.dataset.tab}`)?.classList.remove("hidden");
    });
  });

  // ===== Data Loaders =====
  let allPosts: any[] = [];
  let allProjects: any[] = [];
  let allQuotes: any[] = [];
  let allSettings: Record<string, any> = {};
  let allContacts: any[] = [];
  let allCommentsAdmin: any[] = [];
  let contactPage = 1;
  let commentPage = 1;

  async function loadAllData() {
    await Promise.allSettled([
      loadPosts(),
      loadProjects(),
      loadQuotes(),
      loadSettings(),
      loadDashboardStats(),
    ]);
  }

  // ----- Dashboard -----
  async function loadDashboardStats() {
    try {
      const stats = await apiGet("/api/admin/stats");
      const el = (id: string) => document.getElementById(id);
      if (el("stat-published")) el("stat-published")!.textContent = String(stats.posts ?? 0);
      if (el("stat-drafts")) el("stat-drafts")!.textContent = String(stats.drafts ?? 0);
      if (el("stat-projects")) el("stat-projects")!.textContent = String(stats.projects ?? 0);
      if (el("stat-quotes")) el("stat-quotes")!.textContent = String(stats.quotes ?? 0);
      if (el("stat-contacts")) el("stat-contacts")!.textContent = String(stats.contacts ?? 0);
      if (el("stat-unread")) el("stat-unread")!.textContent = String(stats.unreadContacts ?? 0);
      if (el("stat-comments")) el("stat-comments")!.textContent = String(stats.comments ?? 0);
      if (el("stat-visitors")) el("stat-visitors")!.textContent = String(stats.onlineVisitors ?? 0);

      const recentPostsEl = document.getElementById("recent-posts");
      if (recentPostsEl && stats.recentPosts?.length) {
        recentPostsEl.innerHTML = stats.recentPosts.map((p: any) =>
          `<div class="flex items-center justify-between py-1.5 border-b border-border/20 last:border-0">
            <span class="text-sm truncate flex-1 ${p.draft ? "text-orange-400/70" : ""}">${esc(p.title || "")}</span>
            <span class="text-[10px] text-muted-foreground/40 ml-2">${p.created_at ? new Date(p.created_at).toLocaleDateString("zh-CN") : ""}</span>
          </div>`
        ).join("");
      } else if (recentPostsEl) {
        recentPostsEl.innerHTML = '<p class="text-xs text-muted-foreground/40">暂无文章</p>';
      }

      const recentCommentsEl = document.getElementById("recent-comments");
      if (recentCommentsEl && stats.recentComments?.length) {
        recentCommentsEl.innerHTML = stats.recentComments.map((c: any) =>
          `<div class="py-1.5 border-b border-border/20 last:border-0">
            <div class="flex items-center gap-2">
              <span class="text-xs font-medium">${esc(c.author || "匿名")}</span>
              <span class="text-[10px] text-muted-foreground/40">于 ${c.post_slug || "未知文章"}</span>
            </div>
            <p class="text-xs text-muted-foreground/60 truncate mt-0.5">${esc(c.content || "")}</p>
          </div>`
        ).join("");
      } else if (recentCommentsEl) {
        recentCommentsEl.innerHTML = '<p class="text-xs text-muted-foreground/40">暂无评论</p>';
      }
    } catch {
      // fallback silent
    }
  }

  function updateDashboard() {
    loadDashboardStats();
  }

  // ----- Posts -----
  async function loadPosts() {
    try {
      allPosts = await apiGet("/api/posts?drafts=true");
    } catch { allPosts = []; }
    renderPosts();
    updateDashboard();
  }

  function renderPosts() {
    const tbody = document.getElementById("posts-tbody");
    if (!tbody) return;
    const q = (document.getElementById("post-search") as HTMLInputElement)?.value?.toLowerCase() || "";
    const statusFilter = (document.getElementById("post-status-filter") as HTMLSelectElement)?.value || "";

    let filtered = allPosts.filter((p) => {
      if (q && !p.title?.toLowerCase().includes(q)) return false;
      if (statusFilter === "published" && p.draft) return false;
      if (statusFilter === "draft" && !p.draft) return false;
      return true;
    });

    if (!filtered.length) {
