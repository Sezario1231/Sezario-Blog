    <!-- ===== 文章编辑器 Modal ===== -->
    <div id="post-editor-overlay" class="fixed inset-0 z-50 bg-black/50 backdrop-blur-sm hidden items-center justify-center p-4">
      <div class="bg-card border border-border/40 rounded-2xl w-full max-w-4xl max-h-[90vh] overflow-y-auto shadow-2xl">
