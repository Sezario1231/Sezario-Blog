              <label class="text-sm font-medium block mb-1.5">标签（逗号分隔）</label>
              <input type="text" id="pe-tags" placeholder="tag1, tag2" class="w-full px-4 py-2.5 rounded-xl border border-border/40 bg-card/50 text-sm focus:outline-none focus:border-primary/40" />
