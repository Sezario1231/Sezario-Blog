---
import BaseLayout from "@/layouts/BaseLayout.astro";
import TagCloud from "@/components/TagCloud.astro";
import Avatar3D from "@/components/Avatar3D.astro";
import RandomQuote from "@/components/RandomQuote.astro";
import ContributionCalendar from "@/components/ContributionCalendar.astro";
import StatusCard from "@/components/StatusCard.astro";
import { getSupabase } from "@/lib/supabase";

const supabase = getSupabase();
const { data: settingsData } = await supabase.from("site_settings").select("key, value");
const settings: Record<string, string> = {};
if (settingsData) {
  for (const row of settingsData) {
    settings[row.key] = row.value;
  }
}

const rawBio = settings.about_bio || "我是Sezario，一名正在路上的技术爱好者。\n热衷于探索人工智能相关技术，平时喜欢折腾各类有趣的项目与技术工具。\n在这里记录自己的学习过程、踩坑笔记与实践感悟，沉淀技术，慢慢成长。\n欢迎来访，一起交流学习。";
const bioParagraphs = Array.isArray(rawBio) ? rawBio : String(rawBio).split("\n");

const rawTech = settings.about_tech_stack || "AI,Python,TypeScript,React,Astro,Node.js,Tailwind CSS,Git,Linux";
const techStack = Array.isArray(rawTech) ? rawTech : String(rawTech).split(",").map((t: string) => t.trim());
---

<BaseLayout title="关于 - Sezario的个人小屋" description="关于Sezario，一名正在路上的技术爱好者。">
  <section class="container max-w-4xl mx-auto px-5 md:px-8 py-16 md:py-24">
    <div class="mb-14" data-animate>
      <Avatar3D name="Sezario" avatarUrl="/avatar.jpg" />
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-3 text-center">关于</h1>
    </div>

    <div class="mb-12" data-animate>
      <RandomQuote />
    </div>

    <div class="space-y-6 mb-20 text-muted-foreground leading-relaxed" data-animate>
      {bioParagraphs.map((p: string) => (
        <p>{p}</p>
      ))}
      <p>欢迎来访，一起交流学习。欢迎通过<a href="/contact" class="text-primary hover:underline">联系</a>页面找到我。</p>
    </div>

    <div class="mb-20" data-animate>
      <h2 class="text-2xl font-bold tracking-tight mb-8">技术栈</h2>
      <TagCloud tags={techStack} />
    </div>

    <div class="mb-20" data-animate>
      <h2 class="text-2xl font-bold tracking-tight mb-8">发文记录</h2>
      <ContributionCalendar />
    </div>

    <div data-animate>
      <h2 class="text-2xl font-bold tracking-tight mb-8">实时状态</h2>
      <StatusCard />
    </div>
  </section>
</BaseLayout>
